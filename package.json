{
  "name": "apexworkspace",
  "version": "1.0.0",
  "description": "Desktop workspace application with document editing and notifications",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Ahan Jadhav",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.legendarykiddgamer.apexworkspace",
    "productName": "ApexWorkspace",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "publish": {
      "provider": "github",
      "owner": "LegendaryKiddGamer",
      "repo": "apexworkspace"
    }
  }
}
